<launch>
    <!-- Static transform: camera_init -> map (identity transform since they're both fixed world frames) -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="camera_init_to_map_tf" 
          args="0 0 0 0 0 0 camera_init map" />
    
    <!-- REMOVED: odom_relay.py - odometry relay now handled by register_node -->
    <!-- register_node publishes to: /odom_ugv, /odom_uav, /spot/odom, /spot_Odometry -->
    
    <!-- Bridge: SLIDE_SLAM poses → /semantic_objects_slide_slam (map_manager subscribes and merges into /semantic_objects) -->
    <node 
        pkg="object_modeller" 
        type="slide_slam_to_map_manager_bridge.py" 
        name="slide_slam_to_map_manager_bridge" 
        output="screen">
        <param name="source_frame" value="camera_init" />
        <param name="target_frame" value="map" />
        <param name="output_topic" value="/semantic_objects_slide_slam" />
    </node>
    
    <!-- Detection adapter: converts SLIDE_SLAM segmented point cloud to vision_msgs/Detection2DArray -->
    <!-- This feeds map_manager's raw detection pipeline so it can generate bounding boxes -->
    <node 
        pkg="object_modeller" 
        type="detection_adapter.py" 
        name="detection_adapter" 
        output="screen">
        <param name="input_pointcloud_topic" value="/robot0/sem_detection/pointcloud" />
        <param name="output_detection_topic" value="/yolo/detection" />
        <param name="min_points_threshold" value="50" />
        <param name="confidence_threshold" value="0.3" />
        <param name="image_width" value="1280" />
        <param name="image_height" value="720" />
    </node>
    
    <!-- OPTIMIZED: Use topic_tools/relay with larger queue_size to reduce latency -->
    <!-- Depth image relay: map_manager needs depth image synchronized with detections -->
    <!-- Use aligned_depth_to_color which is aligned to the color image used by YOLO -->
    <node pkg="topic_tools" type="relay" name="depth_relay" 
          args="/robot0/camera/aligned_depth_to_color/image_raw /depth_uav" output="screen" respawn="false">
        <param name="lazy" value="false"/>
    </node>
    
    <!-- Point cloud relay: map_manager expects /point_cloud_uav for range sensing -->
    <node pkg="topic_tools" type="relay" name="pointcloud_relay" 
          args="/cloud_registered /point_cloud_uav" output="screen" respawn="false">
        <param name="lazy" value="false"/>
    </node>
    
    <!-- YOLO visualization relay: RViz expects /yolo/visualization -->
    <node pkg="topic_tools" type="relay" name="yolo_viz_relay" 
          args="/robot0/sem_detection/detections_image /yolo/visualization" output="screen" respawn="false">
        <param name="lazy" value="false"/>
    </node>
</launch>
