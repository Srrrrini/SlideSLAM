<launch>
    <!-- Static transform: camera_init -> map (identity transform since they're both fixed world frames) -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="camera_init_to_map_tf" 
          args="0 0 0 0 0 0 camera_init map" />
    
    <!-- Odometry relay: subscribes to /Odometry (source from faster-lio) and republishes to /odom_ugv, /odom_uav, and /spot/odom -->
    <!-- Subscribe directly from source to avoid feedback loops and ensure stability -->
    <node 
        pkg="object_modeller" 
        type="odom_relay.py" 
        name="odom_relay" 
        output="screen">
        <param name="input_topic" value="/Odometry" />
        <rosparam param="output_topics">["/odom_ugv", "/odom_uav", "/spot/odom","/spot_Odometry"]</rosparam>
        <param name="target_frame" value="map" />
    </node>
    
    <!-- Bridge node to convert SLIDE_SLAM object poses to map_manager format -->
    <node 
        pkg="object_modeller" 
        type="slide_slam_to_map_manager_bridge.py" 
        name="slide_slam_to_map_manager_bridge" 
        output="screen">
        <param name="source_frame" value="camera_init" />
        <param name="target_frame" value="map" />
    </node>
</launch>

